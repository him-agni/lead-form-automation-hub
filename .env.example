# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/form-automation-hub
DASHBOARD_API_KEY=replace-with-a-long-random-value

# ── Tally ─────────────────────────────────────────────────────────────────────
# Found in Tally → Settings → Webhooks → Signing secret
TALLY_SIGNING_SECRET=

# ── Airtable ──────────────────────────────────────────────────────────────────
# Personal access token: airtable.com/create/tokens
AIRTABLE_API_KEY=
# Found in the URL: airtable.com/<BASE_ID>/...
AIRTABLE_BASE_ID=
# Exact table name (case-sensitive)
AIRTABLE_TABLE_NAME=Submissions

# ── Discord ───────────────────────────────────────────────────────────────────
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Paste the entire service account JSON as a single-line string
# (escape inner quotes or use JSON.stringify output)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Found in the Sheets URL: /spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=
